pipeline {
    agent any
    stages {
        stage('Clone') {
            steps {
                git branch: 'main', url: 'https://github.com/YOUR_USERNAME/portfolio.git'
            }
        }
        stage('Build') {
            steps {
                sh 'docker build -t portfolio:latest .'
            }
        }
        stage('Deploy') {
            steps {
                sh '''
                    docker stop portfolio-container || true
                    docker rm portfolio-container || true
                    docker run -d --name portfolio-container -p 80:80 portfolio:latest
                '''
            }
        }
    }
}